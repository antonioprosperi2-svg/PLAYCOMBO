<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  /* 1. LO SFONDO: Qui carichi la tua foto (Mare o Primavera) */
  body {
      background-image: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=1920&q=80');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      margin: 0;
  }

  /* 2. EFFETTO TRASPARENZA: Header che non copre la vista */
  .header {
      display: flex; justify-content: space-between; align-items: center;
      padding: 15px; background: rgba(0, 0, 0, 0.4); /* Trasparente */
      backdrop-filter: blur(10px); /* Sfoca leggermente il mare dietro */
      border-bottom: 2px solid #39FF14; position: sticky; top: 0; z-index: 100;
  }

  /* 3. LE ICONE: Niente piÃ¹ scatole nere, solo vetro e neon */
  .grid-giochi {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 20px; padding: 25px;
  }

  .btn-gioco {
      background: rgba(255, 255, 255, 0.1);
      border: 2px solid #39FF14;
      border-radius: 20px;
      overflow: hidden;
      cursor: pointer;
      transition: 0.4s;
      box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
      backdrop-filter: blur(4px); /* Effetto vetro */
  }

  .btn-gioco:hover { transform: translateY(-10px) scale(1.05); box-shadow: 0 0 20px #39FF14; }
  .btn-gioco img { width: 100%; display: block; filter: brightness(0.9); }

  /* Il resto del tuo stile (Intro, Game View ecc.) rimane uguale */
  #intro {
   position: fixed;
   top: 0; left: 0;
   width: 100%; height: 100%;
   /* Un velo leggerissimo per far leggere le scritte, ma il mare si vede sotto! */
   background: rgba(0, 0, 0, 0.2);
   backdrop-filter: blur(3px); /* Un leggero effetto nebbia che rende tutto elegante */
   display: flex;
   flex-direction: column;
   justify-content: center;
   align-items: center;
   z-index: 5000;
}

  .rombo { width: 100px; height: 100px; border: 4px solid #39FF14; transform: rotate(45deg); display: flex; justify-content: center; align-items: center; box-shadow: 0 0 20px #39FF14; animation: gira 4s infinite linear; }
  @keyframes gira { from { transform: rotate(45deg); } to { transform: rotate(405deg); } }
  #game-view { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #fff; z-index: 6000; }
  .close-btn { position: absolute; top: 15px; left: 15px; background: rgba(255, 255, 255, 0.1); color: #fff; border: none; padding: 10px 20px; font-weight: bold; border-radius: 5px; cursor: pointer; }
  .page { display: none; }
  .active { display: block; }
  .btn-video { background: #39FF14; color: #fff; border: none; padding: 15px; width: 100%; max-width: 300px; font-weight: bold; border-radius: 10px; cursor: pointer; margin-top: 20px;}
</style>
</head>
<body>

<div id="intro">
  <div class="rombo"><span style="transform: rotate(-45deg);color:#fff">HONEST<br>PLAY</span></div>
  <h1 style="color:#39FF14; margin-top:40px; text-shadow: 0 0 10px #39FF14;">HONEST PLAY COMBO</h1>
  <button class="btn-video" onclick="document.getElementById('intro').style.display='none'">ENTRA NEL PORTALE</button>
</div>

<div id="game-view">
  <button class="close-btn" onclick="chiudiGioco()">X CHIUDI</button>
  <iframe id="game-iframe" style="width:100%; height:100%; border:none;"></iframe>
</div>

<div class="header">
  <div onclick="location.reload()" style="cursor:pointer; font-weight:bold;color:#fff">EXIT</div>
  <div style="border: 2px solid #39FF14; padding: 5px 15px; border-radius: 10px;color:#fff">play<span id="punti">combo</span></div>
  <div onclick="mostra('info')" style="cursor:pointer; font-weight:bold;color: #fff;">INFO</div>
</div>

<div id="main" class="page active">
  <div class="grid-giochi">
      <div class="btn-gioco" onclick="apri('https://html5.gamemonetize.co/r09woub5zb1k3b101w7k0zkb98bog5md/')"><img src="https://img.gamemonetize.com/r09woub5zb1k3b101w7k0zkb98bog5md/512x384.jpg"></div>
      <div class="btn-gioco" onclick="apri('https://html5.gamemonetize.co/55ad86ncj3wmgtjalsmm61a2r4myf5lx/')"><img src="https://img.gamemonetize.com/55ad86ncj3wmgtjalsmm61a2r4myf5lx/512x384.jpg"></div>
      <div class="btn-gioco" onclick="apri('https://html5.gamemonetize.co/piyaauly0gfkxkvqqbdvk2wik56ugq8o/')"><img src="https://img.gamemonetize.com/piyaauly0gfkxkvqqbdvk2wik56ugq8o/512x384.jpg"></div>
      <div class="btn-gioco" onclick="apri('https://html5.gamemonetize.co/xuseqfayanszx97p09h6pocckqyd3m4k/')"><img src="https://img.gamemonetize.com/xuseqfayanszx97p09h6pocckqyd3m4k/512x384.jpg"></div>
      </div>
</div>

<div id="info" class="page" style="padding:20px; text-align:center;">
  <h2 style="color:#39FF14">INFO & PRIVACY</h2>
  <p>Honest Play Combo: Portale Nativo Stagionale:::::Ora ci sara' da divertirsi BOOOOOOOMMMM</p>
  <button class="btn-video" onclick="mostra('main')">TORNA AI GIOCHI</button>
</div>

<script>
  function apri(url) {
      document.getElementById('game-iframe').src = url;
      document.getElementById('game-view').style.display = 'block';
  }
  function chiudiGioco() {
      document.getElementById('game-view').style.display = 'none';
      document.getElementById('game-iframe').src = '';
  }
  function mostra(id) {
      document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
      document.getElementById(id).classList.add('active');
  }
</script>
</body>
</html>

